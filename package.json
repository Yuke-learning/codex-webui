{
  "name": "codex-webui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-only web console for managing Codex app-server threads.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build-client.mjs",
    "dev": "npm run build && node server.mjs",
    "start": "npm run build && node server.mjs",
    "service:install": "node scripts/launchd-service.mjs install",
    "service:restart": "node scripts/launchd-service.mjs restart",
    "service:status": "node scripts/launchd-service.mjs status",
    "service:uninstall": "node scripts/launchd-service.mjs uninstall",
    "test": "npm run build && node --test"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.1",
    "markdown-it": "^14.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1"
  }
}
